# =============================================================================
# 灵犀掌柜 - 根环境变量模板
# 使用方法：
#   cp .env.example .env
#   按实际情况编辑 .env 中的值
#   .env 文件已加入 .gitignore，不会提交到版本库
#
# 生产部署：通过 CI/CD Secret 注入，不要在文件中填写真实密钥
# =============================================================================

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DB=linximanager
POSTGRES_USER=linxi
# 开发默认值，生产必须替换为强密码（建议 32+ 位随机字符串）
POSTGRES_PASSWORD=linxi_dev_password

# =============================================================================
# Redis
# =============================================================================
# 开发默认值，生产必须替换
REDIS_PASSWORD=redis_dev_password

# =============================================================================
# MinIO 对象存储
# =============================================================================
MINIO_ROOT_USER=minioadmin
# 开发默认值，生产必须替换（至少 8 位）
MINIO_ROOT_PASSWORD=minio_dev_password

# =============================================================================
# Meilisearch 全文搜索
# =============================================================================
# 开发默认值，生产必须替换为随机字符串
MEILI_MASTER_KEY=meili_dev_masterkey

# =============================================================================
# Go 后端服务
# =============================================================================
APP_ENV=development
APP_PORT=8080
# 用于签名 cookie / CSRF，生产必须替换
APP_SECRET=change_me_to_a_random_32_char_secret

# 数据库连接（Compose 内网地址，已通过上面的 POSTGRES_* 变量统一）
DB_HOST=postgres
DB_PORT=5432
DB_NAME=${POSTGRES_DB}
DB_USER=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300

# Redis 连接（config.go 读取 REDIS_ADDR = host:port 格式）
# Compose 内网：redis:6379
REDIS_ADDR=redis:6379
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_DB=0

# JWT 签名密钥，生产必须替换为不同的随机值
JWT_ACCESS_SECRET=dev_jwt_access_secret_change_in_prod
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_prod
JWT_ACCESS_EXPIRE=7200
JWT_REFRESH_EXPIRE=604800

# 限流
RATE_LIMIT_QPS=100
RATE_LIMIT_BURST=200

# MinIO（Compose 内网地址）
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=linximanager
MINIO_USE_SSL=false

# Meilisearch（Compose 内网地址）
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=${MEILI_MASTER_KEY}

# AI 引擎 gRPC（Compose 内网地址）
AI_ENGINE_GRPC=ai-engine:50051

# 日志
LOG_LEVEL=debug
LOG_FORMAT=text

# CORS（逗号分隔，匹配管理后台访问地址）
CORS_ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# AI 引擎（Python FastAPI）
# =============================================================================
AI_ENGINE_ENV=development
# LLM API Key（对接 Claude / OpenAI 等），生产必须填入真实值
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=claude-opus-4-7

# =============================================================================
# 微信支付 / 小程序（生产必填）
# =============================================================================
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_API_KEY=your_wechat_api_key
WECHAT_NOTIFY_URL=http://localhost:8080/api/v1/payment/notify

# =============================================================================
# 短信（生产必填）
# =============================================================================
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=your_sms_access_key
SMS_SECRET_KEY=your_sms_secret_key
SMS_SIGN_NAME=灵犀掌柜
SMS_TEMPLATE_CODE=SMS_000000
