# ==================== 服务配置 ====================
APP_ENV=development
APP_PORT=8080
APP_SECRET=your-app-secret-key-here

# ==================== 数据库 ====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=linximanager
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=3600

# ==================== Redis ====================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== JWT ====================
JWT_ACCESS_SECRET=your-jwt-access-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret
JWT_ACCESS_EXPIRE=7200      # 2小时，单位秒
JWT_REFRESH_EXPIRE=604800   # 7天，单位秒

# ==================== 限流 ====================
RATE_LIMIT_QPS=100
RATE_LIMIT_BURST=200

# ==================== 对象存储 ====================
OSS_ENDPOINT=http://localhost:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin
OSS_BUCKET=linximanager

# ==================== 短信 ====================
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=灵犀掌柜
SMS_TEMPLATE_CODE=SMS_000000

# ==================== 微信 ====================
WX_MERCHANT_APPID=
WX_MERCHANT_SECRET=
WX_CONSUMER_APPID=
WX_CONSUMER_SECRET=
WX_PAY_MCH_ID=
WX_PAY_KEY=
