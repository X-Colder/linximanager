# 灵犀掌柜 - 生产环境变量模板
# ⚠️ 此文件仅为模板，实际值通过 CI/CD Secret 注入，不要在此填写真实密钥

# ============ 应用 ============
APP_ENV=production
APP_PORT=8080
APP_DEBUG=false

# ============ 数据库 ============
DB_HOST=postgres-service
DB_PORT=5432
DB_NAME=linximanager
DB_USER=linxi
DB_PASSWORD=INJECT_FROM_SECRET
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300
DB_SSL_MODE=require

# ============ Redis ============
REDIS_HOST=redis-service
REDIS_PORT=6379
REDIS_PASSWORD=INJECT_FROM_SECRET
REDIS_DB=0

# ============ MinIO ============
MINIO_ENDPOINT=minio-service:9000
MINIO_ACCESS_KEY=INJECT_FROM_SECRET
MINIO_SECRET_KEY=INJECT_FROM_SECRET
MINIO_BUCKET=linximanager
MINIO_USE_SSL=true

# ============ Meilisearch ============
MEILI_HOST=http://meilisearch-service:7700
MEILI_MASTER_KEY=INJECT_FROM_SECRET

# ============ AI 引擎 ============
AI_ENGINE_GRPC=ai-engine-service:50051

# ============ JWT ============
JWT_SECRET=INJECT_FROM_SECRET
JWT_ACCESS_EXPIRE=7200
JWT_REFRESH_EXPIRE=604800

# ============ 微信 ============
WECHAT_APP_ID=INJECT_FROM_SECRET
WECHAT_MCH_ID=INJECT_FROM_SECRET
WECHAT_API_KEY=INJECT_FROM_SECRET
WECHAT_NOTIFY_URL=https://linximanager.com/api/v1/payment/notify

# ============ LLM ============
LLM_API_KEY=INJECT_FROM_SECRET
LLM_MODEL=claude-opus-4-7

# ============ 日志 ============
LOG_LEVEL=info
LOG_FORMAT=json

# ============ 限流 ============
RATE_LIMIT_RPM=100
CORS_ALLOWED_ORIGINS=https://admin.linximanager.com
