# 灵犀掌柜 - 开发环境变量
# 复制此文件为 .env.development.local 并填入实际值（不要提交 .local 文件）

# ============ 应用 ============
APP_ENV=development
APP_PORT=8080
APP_DEBUG=true

# ============ 数据库 ============
DB_HOST=localhost
DB_PORT=5432
DB_NAME=linximanager
DB_USER=linxi
DB_PASSWORD=linxi_dev_password
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300

# ============ Redis ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password
REDIS_DB=0

# ============ MinIO ============
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio_dev_password
MINIO_BUCKET=linximanager
MINIO_USE_SSL=false

# ============ Meilisearch ============
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=meili_dev_masterkey

# ============ AI 引擎 ============
AI_ENGINE_GRPC=localhost:50051

# ============ JWT ============
JWT_SECRET=dev_jwt_secret_change_in_prod_32chars
JWT_ACCESS_EXPIRE=7200
JWT_REFRESH_EXPIRE=604800

# ============ 微信 ============
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_API_KEY=your_wechat_api_key
WECHAT_NOTIFY_URL=http://localhost:8080/api/v1/payment/notify

# ============ LLM ============
LLM_API_KEY=your_llm_api_key
LLM_MODEL=claude-opus-4-7

# ============ 日志 ============
LOG_LEVEL=debug
LOG_FORMAT=text

# ============ 限流 ============
RATE_LIMIT_RPM=1000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
